# CivicVoice AI Configuration Templates

# To enable real LLM routing paths, copy this file as '.env' in this directory 
# and input your keys:

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ADMIN_PASSWORD=demopass2026
INTAKE_API_KEY=intake_secret_token

# Database Integration (SQLite fallback if DATABASE_URL is unset)
DATABASE_URL=postgresql://postgres:password@db.xxxxxx.supabase.co:5432/postgres

# Supabase Storage Integration (requires service_role/secret key for file uploads)
# NOTE: Using anon/public keys will fail with a permission error. Use your secret_role or new sb_secret_... key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-secret-key-here
SUPABASE_BUCKET=complaint-media
